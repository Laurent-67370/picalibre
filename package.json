{
  "name": "picalibre",
  "version": "2.24.13",
  "description": "Gestionnaire de photos open-source inspiré de Picasa — Electron + React + TypeScript + SQLite",
  "main": "./out/main/index.js",
  "author": {
    "name": "Laurent-67370",
    "email": "laurent-67370@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@vladmandic/human": "^3.3.6",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.3.9",
    "exiftool-vendored": "^37.0.0",
    "heic-convert": "^2.1.0",
    "leaflet": "^1.9.4",
    "sharp": "^0.33.5",
    "xxhash-wasm": "^1.1.0"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@tanstack/react-virtual": "^3.11.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "fr.lhusser.picalibre",
    "productName": "PicaLibre",
    "electronLanguages": [
      "fr",
      "en-US"
    ],
    "files": [
      "out/**",
      "!**/node_modules/@img/*musl*/**",
      "!**/node_modules/@vladmandic/human/models/**",
      "**/node_modules/@vladmandic/human/models/{blazeface,faceres}.{bin,json}",
      "!**/node_modules/better-sqlite3/{src,deps,build/Release/obj.target,build/Release/obj,prebuilds}/**",
      "!**/node_modules/better-sqlite3/build/Release/{test_extension.node,*.a}",
      "!**/node_modules/exiftool-vendored.pl/bin/{Changes,windows_exiftool.txt,README,META.*,Makefile.PL,*.spec,validate,build_*,MANIFEST,pp_build_exe.args}/**",
      "!**/node_modules/exiftool-vendored.pl/bin/Changes",
      "!**/node_modules/exiftool-vendored.pl/bin/windows_exiftool.txt",
      "!**/node_modules/exiftool-vendored.pl/bin/README",
      "!**/node_modules/exiftool-vendored.pl/bin/META.{json,yml}",
      "!**/node_modules/exiftool-vendored.pl/bin/Makefile.PL",
      "!**/node_modules/exiftool-vendored.pl/bin/perl-Image-ExifTool.spec",
      "!**/node_modules/exiftool-vendored.pl/bin/{validate,build_geolocation,build_tag_lookup,MANIFEST,pp_build_exe.args}",
      "!**/node_modules/ffmpeg-static/{example.js,install.js,ffmpeg.LICENSE,ffmpeg.README,LICENSE,README.md,types}",
      "!**/node_modules/**/{*.md,*.map,*.d.ts,*.d.mts,*.d.cts,CHANGELOG*,README*,LICENSE*,docs,doc,test,tests,__tests__,example,examples,.github}/**",
      "!**/node_modules/**/*.{md,map,d.ts}"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "node_modules/better-sqlite3/**",
      "node_modules/exiftool-vendored*/**",
      "node_modules/ffmpeg-static/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics",
      "files": [
        "!**/node_modules/ffmpeg-static/**"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.photography"
    },
    "afterPack": "scripts/afterPack.js",
    "publish": {
      "provider": "github",
      "owner": "Laurent-67370",
      "repo": "picalibre"
    },
    "compression": "maximum"
  }
}
